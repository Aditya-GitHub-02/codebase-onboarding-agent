# LLM_PROVIDER options: "groq" (default, free, no card needed, 100k tokens/day),
# "gemini" (higher free-tier caps but requires a billing method on file with Google),
# "ollama" (fully free, no rate limits, runs locally, requires Ollama installed)
LLM_PROVIDER=groq

GROQ_API_KEY=
GOOGLE_API_KEY=

# Only used if LLM_PROVIDER=ollama. Defaults shown.
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

GITHUB_TOKEN=
